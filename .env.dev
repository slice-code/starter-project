# Development Environment Configuration
NODE_ENV=development
APP_PORT=3004

# Database - Development (Docker PostgreSQL)
DATABASE_URL=postgres://pjtki_dev:dev_password_123@localhost:5433/pjtki_dev

# JWT (lebih relaxed untuk development)
JWT_SECRET=dev-secret-key-not-for-production-1234567890
JWT_MAX_AGE_SEC=86400  # 1 hari

# Admin Account Development
SEED_ADMIN=true
ADMIN_EMAIL=admin@localhost
APP_NAME=TKI Management Dev
ADMIN_PASSWORD=dev123
ADMIN_ROLE=admin

# Logging (verbose untuk development)
LOG_LEVEL=debug

# Google Gemini OCR (for KTP recognition)
# Get API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash

# Disable security features untuk development (optional)
# CORS_ORIGINS=*
# UPLOAD_MAX_SIZE=52428800  # 50MB untuk testing
