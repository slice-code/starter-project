{
  "path": "/about",
  "type": "page",
  "config": {
    "title": "Tentang",
    "children": [
      {
        "type": "card",
        "children": [
          { "type": "heading", "level": 1, "text": "Admin Starter" },
          { "type": "text", "text": "Template admin JSON-driven. Halaman CRUD dan UI didefinisikan di appjson/*.json, skema database di schema/*.json." },
          { "type": "heading", "level": 3, "text": "Termasuk" },
          { "type": "list", "items": [
            "Auth JWT + role-based menu",
