# Port aplikasi di host (browser: http://localhost:8005)
APP_PORT=8005

# Branding instalasi (global / multi-tenant — jangan hardcode di kode)
APP_NAME=TKI Management
# APP_TITLE=   # opsional; default = APP_NAME
# ORG_NAME=PT PJTKI   # default cetak surat (nama direktur sengaja kosong)
# ORG_ADDRESS=Jl. Contoh No. 1 RT.01 RW.01, Kel. Contoh, Kec. Contoh, Kab. Contoh, Provinsi Contoh, Indonesia. Kode pos 12345
# ORG_EMAIL=info@contoh-pjtki.co.id   # email kontak header biodata/cetak
# ORG_PRINT_LOCATION=Kota Contoh, Provinsi Contoh
# APP_LOGIN_SUBTITLE=
# APP_SHOW_LOGIN_DEMO=false   # true = tampilkan hint email dev di halaman login

# Akun admin awal (SEED_ADMIN tidak false)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=
ADMIN_NAME=Administrator
# ENSURE_PRIMARY_ADMIN=true   # reset password admin setiap init DB (hanya dev)

# PostgreSQL (wajib untuk docker compose)
POSTGRES_USER=pjtki
POSTGRES_PASSWORD=pjtki
POSTGRES_DB=pjtki
# Postgres tidak di-expose ke host — hanya jaringan Docker internal `pjtki` (hostname: db)

# Di dalam Docker, app memakai hostname service `db` di network pjtki
# DATABASE_URL=postgres://pjtki:pjtki@db:5432/pjtki
# Image Docker sudah include LibreOffice (soffice) untuk cetak PDF dari template Word.

# Lokal npm start (SQLite):
# Pakai file env.local (sudah disiapkan) — DATABASE_URL kosong → data.db (sql.js)

# JWT (WAJIB ganti di production — lihat README.md § Keamanan)
# Generate: openssl rand -base64 64
JWT_SECRET=pjtki-docker-change-me

# Google Gemini — OCR gambar (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Model vision OCR KTP (default: gemini-2.5-flash)
GEMINI_OCR_MODEL=gemini-2.5-flash
