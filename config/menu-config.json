{
  "_description": "Menu & role permissions — starter admin template",
  "_version": "1.0.0",
  "metadata": {
    "appName": "Admin Starter",
    "sidebarTheme": "teal",
    "ownerRoles": ["admin"],
    "defaultRolePermissions": {
      "can_create": 0,
      "can_update": 0,
      "can_delete": 0
    }
  },
  "menuStructure": [
    {
      "name": "Dashboard",
      "icon": "fas fa-home",
      "path": "/",
      "type": "single",
      "sortOrder": 1
    },
    {
      "name": "Data",
      "icon": "fas fa-database",
      "path": "/data",
      "type": "group",
      "sortOrder": 2,
      "children": [
        {
          "name": "Kategori",
          "icon": "fas fa-tags",
          "path": "/categories",
          "sortOrder": 1
        },
        {
          "name": "Workflow",
          "icon": "fas fa-sitemap",
          "path": "/workflow",
          "sortOrder": 2
        }
      ]
    },
    {
      "name": "Pengaturan",
      "icon": "fas fa-gear",
      "path": "/settings",
      "type": "group",
      "sortOrder": 90,
      "ownerOnly": true,
      "children": [
        {
          "name": "Pengguna",
          "icon": "fas fa-user-shield",
          "path": "/users",
          "sortOrder": 1,
          "ownerOnly": true
        },
        {
          "name": "Cabang",
          "icon": "fas fa-code-branch",
          "path": "/datacabang",
          "sortOrder": 2,
          "ownerOnly": true
        },
        {
          "name": "Profil Perusahaan",
          "icon": "fas fa-building",
          "path": "/profil-perusahaan",
          "sortOrder": 3,
          "ownerOnly": true
        },
        {
          "name": "Menu & Role",
          "icon": "fas fa-sitemap",
          "path": "/menu-role-manager",
          "sortOrder": 4,
          "ownerOnly": true
        }
      ]
    }
  ],
  "roles": {
    "admin": {
      "label": "Administrator",
      "menuPaths": ["*"],
      "permissions": {
        "default": { "can_create": 1, "can_update": 1, "can_delete": 1 },
        "exceptions": {}
      }
    }
  }
}
